# === MongoDB ===
# Get a free cluster at https://mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/daywork?retryWrites=true&w=majority

# === JWT ===
# Generate a random secret: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# === Server ===
PORT=5000
NODE_ENV=development

# === CORS (optional, comma-separated origins) ===
# CORS_ORIGIN=https://your-frontend.vercel.app

# === Payme Merchant API ===
# Get merchant ID from https://payme.uz
# PAYME_MERCHANT_ID=your-payme-merchant-id
# PAYME_SECRET_KEY=your-payme-secret-key

# === Click Merchant API ===
# Get service ID & secret from https://click.uz
# CLICK_SERVICE_ID=your-click-service-id
# CLICK_MERCHANT_ID=your-click-merchant-id
# CLICK_SECRET_KEY=your-click-secret-key

# === Frontend (Vite) — add to frontend/.env ===
# VITE_API_URL=https://your-project.vercel.app/api
# VITE_SOCKET_URL=https://your-project.vercel.app
